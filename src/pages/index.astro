title: Home
---

<Base title={title} description={description} activeSection="">
<style>

.nav-links a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: #fff; }

.nav-cta:hover { background: var(--orange-bright) !important; }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    background: var(--navy-deep);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 100px 56px 80px;
    position: relative;
    overflow: hidden;
    gap: 60px;
  }

  /* diagonal slash */
  .hero::before {
    content: '';
    position: absolute;
    right: -60px; top: 0; bottom: 0;
    width: 50%;
    background: #0f1c30;
    clip-path: polygon(12% 0, 100% 0, 100% 100%, 0% 100%);
    pointer-events: none;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 24px;
  }

  .hero-tag::before {
    content: '';
    display: block;
    width: 28px; height: 2px;
    background: var(--orange);
  }

  h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3.8rem, 6.5vw, 6.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 0;
  }

  h1 .accent {
    color: var(--orange);
    display: block;
  }

  .tagline-block {
    margin: 28px 0 0;
    padding: 20px 0 20px 20px;
    border-left: 3px solid var(--orange);
  }

  .tagline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.9);
    text-transform: uppercase;
    line-height: 1.2;
  }

  .tagline .dash { color: var(--orange); }

  .hero-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    margin-top: 10px;
    max-width: 420px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
    align-items: center;
  }

.btn-primary:hover {
    background: var(--orange-bright);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232,95,23,0.4);
  }

.btn-outline:hover {
    border-color: var(--orange);
    color: var(--orange);
  }

  .proof-row {
    display: flex;
    gap: 36px;
    margin-top: 52px;
    padding-top: 36px;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  }

  .proof-item { display: flex; flex-direction: column; gap: 3px; }

  .proof-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 2.2rem;
    color: var(--orange);
    line-height: 1;
  }

  .proof-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
  }

  /* ─── HERO VISUAL ─── */
  .hero-right {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
  }

  .sched-ui {
    background: #1b2d4f;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    width: 420px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.6);
    animation: float 7s ease-in-out infinite;
  }

  @keyframes float {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .ui-bar {
    background: #0f1c30;
    padding: 12px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .ui-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
  }

  .live-dot {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--teal);
    letter-spacing: 0.1em;
  }

  .live-dot::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 6px var(--teal);
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

  .ui-tabs {
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 0 18px;
  }

  .ui-tab {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    padding: 8px 12px 8px 0;
    margin-right: 16px;
    border-bottom: 2px solid transparent;
    cursor: default;
  }

  .ui-tab.active {
    color: var(--orange);
    border-bottom-color: var(--orange);
  }

  .ui-games { padding: 8px 0; }

  .game-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
  }

  .game-row:hover { background: rgba(255,255,255,0.03); }
  .game-row:last-child { border-bottom: none; }

  .gdate {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: rgba(255,255,255,0.35);
    width: 44px;
    flex-shrink: 0;
  }

  .gteams {
    flex: 1;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }

  .gsport {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  .gstatus {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gs-conf { background: var(--teal); box-shadow: 0 0 5px var(--teal); }
  .gs-pend { background: var(--orange); box-shadow: 0 0 5px var(--orange); }
  .gs-open { background: rgba(255,255,255,0.2); }

  .float-chip {
    position: absolute;
    background: var(--navy-deep);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    box-shadow: 0 12px 32px rgba(0,0,0,0.5);
    animation: float 7s ease-in-out infinite;
  }

  .chip-a { top: -18px; right: -24px; animation-delay: -3s; }
  .chip-b { bottom: -18px; left: -28px; animation-delay: -5.5s; }

  .chip-ico {
    width: 28px; height: 28px;
    background: var(--orange-pale);
    border-radius: 5px;
    display: grid;
    place-items: center;
    font-size: 0.9rem;
  }

  .chip-label { font-size: 0.65rem; color: rgba(255,255,255,0.45); display: block; margin-bottom: 1px; }

  /* ─── SECTIONS ─── */
  section { padding: 96px 56px; }

.eyebrow::after {
    content: '';
    display: block;
    height: 1px;
    width: 36px;
    background: var(--orange);
  }

  h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(2.6rem, 4.5vw, 4.2rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 16px;
  }

/* ─── PILLARS ─── */
  .pillars {
    background: var(--navy);
    padding: 0;
  }

  .pillars-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .pillar {
    padding: 64px 48px;
    border-right: 1px solid rgba(255,255,255,0.07);
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .pillar:last-child { border-right: none; }
  .pillar:hover { background: rgba(232,95,23,0.06); }

  .pillar::before {
    content: attr(data-n);
    position: absolute;
    right: 24px; top: 24px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 5rem;
    color: rgba(255,255,255,0.04);
    line-height: 1;
    pointer-events: none;
  }

  .pillar-ico {
    width: 40px; height: 40px;
    background: var(--orange-pale);
    border-radius: 6px;
    display: grid;
    place-items: center;
    font-size: 1.2rem;
    margin-bottom: 20px;
    border: 1px solid rgba(232,95,23,0.2);
  }

  .pillar h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 10px;
  }

  .pillar p {
    font-size: 0.88rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
  }

  /* ─── FEATURES ─── */
  .features-bg { background: var(--bg-warm); }

.feat-tile:hover { background: #fff; }

  .feat-tile::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .feat-tile:hover::after { transform: scaleX(1); }

  .feat-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 14px;
  }

  .feat-tile h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .feat-tile p {
    font-size: 0.87rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  /* ─── SOLUTIONS ─── */
  .sol-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .sol-card {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 32px 26px;
    transition: all 0.25s;
    cursor: default;
    border-top: 3px solid transparent;
  }

  .sol-card:hover {
    border-top-color: var(--orange);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(26,26,26,0.1);
  }

  .sol-role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 10px;
  }

  .sol-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.45rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .sol-card p {
    font-size: 0.83rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin-bottom: 18px;
  }

  .sol-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sol-list li {
    font-size: 0.78rem;
    color: var(--ink-mid);
    padding-left: 14px;
    position: relative;
    line-height: 1.5;
  }

  .sol-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--orange);
    font-size: 0.72rem;
  }

  /* ─── MATRIX ─── */
  .matrix-bg { background: var(--navy-deep); }

  .matrix-bg h2 { color: #fff; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }

  thead th {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 18px;
    text-align: left;
    border-bottom: 2px solid rgba(255,255,255,0.08);
    color: var(--orange);
  }

  thead th:first-child { color: rgba(255,255,255,0.4); }

  tbody td {
    padding: 11px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: middle;
    color: rgba(255,255,255,0.45);
  }

  tbody tr:hover td { background: rgba(255,255,255,0.02); }
  tbody td:first-child { font-weight: 500; color: rgba(255,255,255,0.8); }

  .chk { color: var(--teal); font-size: 1rem; }
  .no { color: rgba(255,255,255,0.15); }
  .partial {
    color: var(--orange);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.67rem;
    letter-spacing: 0.04em;
  }

  /* ─── PRICING ─── */
  .price-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .price-card {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 40px 34px;
    position: relative;
    transition: all 0.25s;
  }

  .price-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 56px rgba(26,26,26,0.1);
  }

  .price-card.hot {
    border-color: var(--orange);
    background: var(--navy);
  }

  .price-badge {
    position: absolute;
    top: -11px; left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 14px;
    border-radius: 20px;
    white-space: nowrap;
    font-weight: 500;
  }

  .price-tier {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .price-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .price-card.hot h3 { color: #fff; }

  .price-desc {
    font-size: 0.84rem;
    color: var(--ink-soft);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .price-card.hot .price-desc { color: rgba(255,255,255,0.45); }

  .price-feats {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }

  .price-feats li {
    font-size: 0.84rem;
    color: var(--ink-mid);
    display: flex;
    gap: 9px;
    align-items: flex-start;
    line-height: 1.5;
  }

  .price-feats li::before {
    content: '✓';
    color: var(--teal);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .price-card.hot .price-feats li { color: rgba(255,255,255,0.65); }

  .btn-light {
    display: block;
    text-align: center;
    background: var(--bg-warm);
    border: 1px solid var(--rule);
    color: var(--navy);
    padding: 13px 24px;
    border-radius: 2px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.2s;
  }

  .btn-light:hover { background: var(--orange); border-color: var(--orange); color: #fff; }

  .btn-primary-block {
    display: block;
    text-align: center;
    background: var(--orange);
    color: #fff;
    padding: 13px 24px;
    border-radius: 2px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.2s;
  }

  .btn-primary-block:hover { background: var(--orange-bright); }

  /* ─── RESOURCES ─── */
  .res-bg { background: var(--bg-warm); }

  .res-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .res-card {
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 28px 24px;
    text-decoration: none;
    display: block;
    transition: all 0.25s;
    border-top: 3px solid transparent;
  }

  .res-card:hover {
    border-top-color: var(--orange);
    background: #fff;
    box-shadow: 0 8px 28px rgba(26,26,26,0.07);
  }

