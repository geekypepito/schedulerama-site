---
import Base from '../layouts/Base.astro';
import aboutPage from '../content/admin/about.json';

const {
  title,
  description,
  hero,
  mission,
  stats,
  values,
  story,
  team,
  cta
} = aboutPage;
---
<Base title={title} description={description} activeSection="company">
<style>
.nav-item>a:hover,.nav-item.active>a{color:#fff;}
  .nav-item.has-drop>a::after{content:' ▾';font-size:0.65rem;}
  .nav-dropdown a:hover{color:#fff;background:rgba(255,255,255,0.06);padding-left:24px;}
  .nav-cta:hover{background:var(--orange-bright)!important;}

.page-hero h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.8rem,6vw,4.5rem);color:#fff;margin-bottom:20px;line-height:1;}
  .page-hero p{font-size:1.1rem;color:rgba(255,255,255,0.6);max-width:600px;margin:0 auto;line-height:1.7;}

  .mission-section{padding:88px 56px;max-width:920px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;}
  .mission-text h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.6rem;line-height:1.05;margin-bottom:24px;}
  .mission-text p{color:var(--ink-mid);line-height:1.8;font-size:1rem;margin-bottom:16px;}
  .mission-visual{background:var(--navy-deep);border-radius:16px;padding:40px;display:flex;flex-direction:column;gap:20px;}
  .stat-row{display:flex;gap:32px;}
  .stat-item{flex:1;}
  .stat-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.8rem;color:var(--orange);line-height:1;}
  .stat-label{font-size:0.78rem;color:rgba(255,255,255,0.45);letter-spacing:0.06em;text-transform:uppercase;margin-top:4px;}
  .stat-divider{height:1px;background:rgba(255,255,255,0.08);}

  .values-section{background:var(--bg-warm);padding:80px 56px;}
  .values-section .section-head{text-align:center;margin-bottom:56px;}
  .values-section h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.4rem;margin-top:8px;}
  .values-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:1100px;margin:0 auto;}
  .value-card{background:#fff;border-radius:10px;padding:32px;border:1px solid var(--rule);}
  .value-ico{font-size:2rem;margin-bottom:16px;}
  .value-card h3{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;margin-bottom:8px;letter-spacing:0.04em;}
  .value-card p{font-size:0.88rem;color:var(--ink-mid);line-height:1.7;}

  .story-section{padding:88px 56px;max-width:760px;margin:0 auto;}
  .story-section h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.4rem;margin-bottom:32px;}
  .story-section p{color:var(--ink-mid);line-height:1.85;font-size:1rem;margin-bottom:20px;}
  blockquote{border-left:4px solid var(--orange);padding:16px 24px;background:var(--orange-pale);border-radius:0 8px 8px 0;margin:32px 0;font-style:italic;font-size:1.05rem;color:var(--ink);line-height:1.7;}

  .team-section{background:var(--bg-warm);padding:80px 56px;}
  .team-section .section-head{text-align:center;margin-bottom:56px;}
  .team-section h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.4rem;margin-top:8px;}
  .team-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;max-width:1100px;margin:0 auto;}
  .team-card{background:#fff;border-radius:10px;overflow:hidden;border:1px solid var(--rule);text-align:center;}
  .team-avatar{height:120px;background:var(--navy);display:flex;align-items:center;justify-content:center;font-size:2.5rem;}
  .team-info{padding:20px 16px;}
  .team-info h4{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.05rem;margin-bottom:4px;letter-spacing:0.04em;}
  .team-info .role{font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--orange);text-transform:uppercase;letter-spacing:0.1em;}
  .team-info p{font-size:0.82rem;color:var(--ink-soft);margin-top:8px;line-height:1.5;}

  .cta-strip h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.6rem;color:#fff;margin-bottom:12px;}
  .cta-strip p{color:rgba(255,255,255,0.55);margin-bottom:32px;}
  .btn-white:hover{background:var(--orange);color:#fff;}

  .footer-brand p{font-size:0.84rem;line-height:1.7;margin-top:12px;max-width:250px;}
  .footer-col h4{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:16px;}
  .footer-col ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
  .footer-col a:hover{color:#fff;}
  .footer-bottom a{color:rgba(255,255,255,0.3);text-decoration:none;}

  .js-loaded .fade-up.on{opacity:1;transform:none;}

  @media(max-width:1024px){
    .values-grid,.team-grid{grid-template-columns:1fr 1fr;}
    .mission-section,.values-section,.team-section,.story-section{padding-left:20px;padding-right:20px;}
  }
</style>

<div class="page-hero">
  <div class="eyebrow">{hero.eyebrow}</div>
  <h1 set:html={hero.heading} />
  <p>{hero.summary}</p>
</div>

<section class="mission-section">
  <div class="mission-text fade-up">
    <div class="eyebrow">{mission.eyebrow}</div>
    <h2>{mission.heading}</h2>
    {mission.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
  </div>
  <div class="mission-visual fade-up" style="transition-delay:0.1s;">
    <div class="stat-row">
      {stats.slice(0, 2).map((stat) => (
        <div class="stat-item">
          <div class="stat-num">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
    <div class="stat-divider"></div>
    <div class="stat-row">
      {stats.slice(2, 4).map((stat) => (
        <div class="stat-item">
          <div class="stat-num">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="values-section">
  <div class="section-head fade-up">
    <div class="eyebrow">{values.eyebrow}</div>
    <h2>{values.heading}</h2>
  </div>
  <div class="values-grid">
    {values.items.map((item, index) => (
      <div class="value-card fade-up" style={index ? `transition-delay:${(index % 3) * 0.08}s;` : undefined}>
        <div class="value-ico">{item.icon}</div>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </div>
    ))}
  </div>
</section>

<section class="story-section">
  <div class="eyebrow fade-up">{story.eyebrow}</div>
  <h2 class="fade-up">{story.heading}</h2>
  {story.paragraphs.slice(0, 2).map((paragraph) => <p class="fade-up">{paragraph}</p>)}
  <blockquote class="fade-up">{story.quote}</blockquote>
  {story.paragraphs.slice(2).map((paragraph) => <p class="fade-up">{paragraph}</p>)}
</section>

<section class="team-section">
  <div class="section-head fade-up">
    <div class="eyebrow">{team.eyebrow}</div>
    <h2>{team.heading}</h2>
  </div>
  <div class="team-grid">
    {team.members.map((member, index) => (
      <div class="team-card fade-up" style={index ? `transition-delay:${index * 0.08}s;` : undefined}>
        <div class="team-avatar">{member.avatar}</div>
        <div class="team-info">
          <h4>{member.name}</h4>
          <div class="role">{member.role}</div>
          <p>{member.bio}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<div class="cta-strip">
  <h2>{cta.heading}</h2>
  <p>{cta.summary}</p>
  <a href={cta.href} class="btn-white">{cta.label}</a>
</div>
</Base>
