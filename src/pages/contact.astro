---
import Base from '../layouts/Base.astro';
import contactPage from '../content/admin/contact.json';

const {
  title,
  description,
  hero = {},
  expectations = [],
  form = {},
  success = {},
  contactBand = [],
} = contactPage;
---

<Base title={title} description={description} activeSection="company">
<style>
.nav-item>a:hover,.nav-item.active>a{color:#fff;}
  .nav-item.has-drop>a::after{content:' ▾';font-size:0.65rem;}
  .nav-dropdown a:hover{color:#fff;background:rgba(255,255,255,0.06);padding-left:24px;}
  .nav-cta:hover{background:var(--orange-bright)!important;}

  .contact-wrapper{display:grid;grid-template-columns:1fr 1fr;min-height:100vh;}
  .contact-left{background:var(--navy-deep);padding:120px 64px 80px;display:flex;flex-direction:column;justify-content:center;}
  .contact-left h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.4rem,4vw,3.8rem);color:#fff;line-height:1.05;margin-bottom:24px;}
  .contact-left p{color:rgba(255,255,255,0.55);font-size:1rem;line-height:1.7;margin-bottom:40px;max-width:420px;}
  .what-to-expect{display:flex;flex-direction:column;gap:20px;}
  .expect-item{display:flex;gap:16px;align-items:flex-start;}
  .expect-num{font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--orange);letter-spacing:0.1em;background:var(--orange-pale);padding:4px 8px;border-radius:4px;flex-shrink:0;margin-top:2px;}
  .expect-item h4{font-weight:600;font-size:0.95rem;color:#fff;margin-bottom:4px;}
  .expect-item p{font-size:0.85rem;color:rgba(255,255,255,0.45);line-height:1.6;margin:0;}

  .contact-right{padding:120px 64px 80px;display:flex;flex-direction:column;justify-content:center;}
  .contact-right h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2rem;margin-bottom:32px;}
  .form-group{margin-bottom:20px;}
  .form-group label{display:block;font-size:0.8rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-mid);margin-bottom:7px;}
  .form-group input,.form-group select,.form-group textarea{
    width:100%;padding:12px 14px;border:1.5px solid var(--rule);border-radius:6px;
    font-family:'Barlow',sans-serif;font-size:0.95rem;background:#fff;color:var(--ink);
    transition:border-color 0.2s,box-shadow 0.2s;outline:none;
  }
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{
    border-color:var(--orange);box-shadow:0 0 0 3px var(--orange-pale);
  }
  .form-group textarea{resize:vertical;min-height:100px;}
  .form-group.invalid input,.form-group.invalid select,.form-group.invalid textarea{border-color:#d14343;box-shadow:0 0 0 3px rgba(209,67,67,0.12);}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .btn-submit{
    width:100%;padding:15px;background:var(--orange);color:#fff;border:none;
    border-radius:6px;font-family:'Barlow',sans-serif;font-weight:700;font-size:1rem;
    letter-spacing:0.05em;cursor:pointer;transition:background 0.2s, opacity 0.2s;margin-top:8px;
  }
  .btn-submit:hover{background:var(--orange-bright);}
  .btn-submit:disabled{opacity:0.75;cursor:wait;}
  .form-note{font-size:0.78rem;color:var(--ink-soft);margin-top:12px;text-align:center;line-height:1.6;}
  .form-error{display:none;margin:0 0 16px;padding:12px 14px;background:#fff1f1;border:1px solid #f2c0c0;border-radius:8px;color:#9f1d1d;font-size:0.9rem;line-height:1.5;}
  .form-error.visible{display:block;}

  .success-panel{display:none;text-align:center;padding:40px;background:var(--teal);color:#fff;border-radius:12px;}
  .success-panel.visible{display:block;}
  .success-panel .ico{font-size:3rem;margin-bottom:16px;}
  .success-panel h3{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.8rem;margin-bottom:8px;}
  .success-panel p{font-size:0.95rem;opacity:0.85;line-height:1.6;}

  .contact-band{background:var(--bg-warm);padding:56px;display:flex;justify-content:center;gap:80px;flex-wrap:wrap;}
  .contact-info-item{text-align:center;}
  .contact-info-item .ico{font-size:1.8rem;margin-bottom:10px;}
  .contact-info-item h4{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:4px;}
  .contact-info-item p{color:var(--ink-mid);font-size:0.9rem;}

  .footer-brand p{font-size:0.84rem;line-height:1.7;margin-top:12px;max-width:250px;}
  .footer-col h4{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:16px;}
  .footer-col ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
  .footer-col a:hover{color:#fff;}
  .footer-bottom a{color:rgba(255,255,255,0.3);text-decoration:none;}

  @media(max-width:1024px){
    .contact-left,.contact-right{padding:100px 24px 56px;}
    .form-row{grid-template-columns:1fr;}
    .contact-band{padding:40px 20px;gap:40px;}
  }
</style>
<div class="contact-wrapper">
  <div class="contact-left">
    <div class="eyebrow">{hero.eyebrow}</div>
    <h1 set:html={hero.heading} />
    <p>{hero.summary}</p>
    <div class="what-to-expect">
      {expectations.map((item) => (
        <div class="expect-item">
          <span class="expect-num">{item.number}</span>
          <div>
            <h4>{item.title}</h4>
            <p>{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="contact-right">
    <h2>{form.heading}</h2>
    <form id="contact-form" novalidate>
      <div class="form-error" id="form-error" role="alert"></div>
      <div class="form-row">
        <div class="form-group" data-field="firstName">
          <label for="fname">{form.firstNameLabel}</label>
          <input type="text" id="fname" name="firstName" placeholder={form.firstNamePlaceholder}>
        </div>
        <div class="form-group" data-field="lastName">
          <label for="lname">{form.lastNameLabel}</label>
          <input type="text" id="lname" name="lastName" placeholder={form.lastNamePlaceholder}>
        </div>
      </div>
      <div class="form-group" data-field="email">
        <label for="email">{form.emailLabel}</label>
        <input type="email" id="email" name="email" placeholder={form.emailPlaceholder}>
      </div>
      <div class="form-group" data-field="organization">
        <label for="org">{form.organizationLabel}</label>
        <input type="text" id="org" name="organization" placeholder={form.organizationPlaceholder}>
      </div>
      <div class="form-group" data-field="role">
        <label for="role">{form.roleLabel}</label>
        <select id="role" name="role">
          <option value="">Select your role…</option>
          {form.roleOptions.map((option) => <option value={option}>{option}</option>)}
        </select>
      </div>
      <div class="form-row">
        <div class="form-group" data-field="schools">
          <label for="schools">{form.schoolsLabel}</label>
          <select id="schools" name="schools">
            <option value="">Select…</option>
            {form.schoolsOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>
        <div class="form-group" data-field="sports">
          <label for="sports">{form.sportsLabel}</label>
          <select id="sports" name="sports">
            <option value="">Select…</option>
            {form.sportsOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>
      </div>
      <div class="form-group" data-field="notes">
        <label for="notes">{form.notesLabel}</label>
        <textarea id="notes" name="notes" placeholder={form.notesPlaceholder}></textarea>
      </div>
      <button class="btn-submit" id="contact-submit" type="submit">{form.submitLabel}</button>
      <p class="form-note">{form.note}</p>
    </form>
    <div class="success-panel" id="success-panel">
      <div class="ico">{success.icon}</div>
      <h3>{success.heading}</h3>
      <p>{success.body}</p>
    </div>
  </div>
</div>

<div class="contact-band">
  {contactBand.map((item) => (
    <div class="contact-info-item">
      <div class="ico">{item.icon}</div>
      <h4>{item.title}</h4>
      <p>{item.body}</p>
    </div>
  ))}
</div>

<script is:inline>
  const formEl = document.getElementById('contact-form');
  const successPanelEl = document.getElementById('success-panel');
  const errorEl = document.getElementById('form-error');
  const submitButtonEl = document.getElementById('contact-submit');
  const endpoint = 'https://app.schedulerama.com/api/marketing/demo-request';

  const getPayload = () => ({
    firstName: document.getElementById('fname')?.value?.trim() ?? '',
    lastName: document.getElementById('lname')?.value?.trim() ?? '',
    email: document.getElementById('email')?.value?.trim() ?? '',
    organization: document.getElementById('org')?.value?.trim() ?? '',
    role: document.getElementById('role')?.value?.trim() ?? '',
    schools: document.getElementById('schools')?.value?.trim() ?? '',
    sports: document.getElementById('sports')?.value?.trim() ?? '',
    notes: document.getElementById('notes')?.value?.trim() ?? '',
  });

  const setFieldErrors = (fields) => {
    document.querySelectorAll('.form-group').forEach((group) => group.classList.remove('invalid'));
    fields.forEach((field) => {
      const group = document.querySelector(`.form-group[data-field="${field}"]`);
      if (group) group.classList.add('invalid');
    });
  };

  const showError = (message) => {
    errorEl.textContent = message;
    errorEl.classList.add('visible');
  };

  const clearError = () => {
    errorEl.textContent = '';
    errorEl.classList.remove('visible');
  };

  formEl?.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearError();
    setFieldErrors([]);

    const payload = getPayload();
    submitButtonEl.disabled = true;
    const originalLabel = submitButtonEl.textContent;
    submitButtonEl.textContent = 'Submitting...';

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json().catch(() => ({}));

      if (!response.ok) {
        const fields = Array.isArray(result.errors) ? result.errors : [];
        if (fields.length) {
          setFieldErrors(fields);
        }
        throw new Error(result.message || 'We could not submit your request right now. Please try again.');
      }

      formEl.style.display = 'none';
      successPanelEl.classList.add('visible');
    } catch (error) {
      showError(error instanceof Error ? error.message : 'We could not submit your request right now. Please try again.');
    } finally {
      submitButtonEl.disabled = false;
      submitButtonEl.textContent = originalLabel;
    }
  });
</script>
</Base>
