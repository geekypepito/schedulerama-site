---
import Base from '../../layouts/Base.astro';
const title = "FAQ";
const description = `Frequently asked questions about ScheduleRama — pricing, setup, importing, roles, and more.`;
---

<Base title={title} description={description} activeSection="resources">
<style>

  .nav-item > a:hover, .nav-item.active > a { color:#fff; }
  .nav-item.has-drop > a::after { content:' ▾'; font-size:0.65rem; }
  
  
  .nav-dropdown a:last-child { border-bottom:none; }
  .nav-dropdown a:hover { background:rgba(232,95,23,0.1); color:#fff; padding-left:22px; }
  
  .nav-cta:hover { background:var(--orange-bright) !important; }

.page-hero::before {
    content:''; position:absolute; right:0; top:0; bottom:0; width:40%;
    background:linear-gradient(90deg, transparent, rgba(232,95,23,0.04));
    pointer-events:none;
  }
  .page-hero-eyebrow {
    display:inline-flex; align-items:center; gap:8px;
    font-family:'JetBrains Mono',monospace; font-size:0.65rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--orange);
    margin-bottom:20px;
  }
  .page-hero-eyebrow::before { content:''; display:block; width:28px; height:2px; background:var(--orange); }
  .page-hero h1 {
    font-family:'Barlow Condensed',sans-serif; font-weight:900;
    font-size:clamp(3rem,6vw,5.5rem); line-height:0.92;
    letter-spacing:-0.01em; color:#fff; text-transform:uppercase;
    max-width:700px; margin-bottom:22px;
  }
  .page-hero h1 span { color:var(--orange); }
  .page-hero p {
    font-size:1.1rem; line-height:1.7;
    color:rgba(255,255,255,0.55); max-width:560px;
  }
  .page-hero-actions { display:flex; gap:14px; margin-top:34px; flex-wrap:wrap; }

  /* ── SECTION COMMON ── */
  section { padding:88px 56px; }
  
  .eyebrow::after { content:''; display:block; height:1px; width:36px; background:var(--orange); }
  h2 {
    font-family:'Barlow Condensed',sans-serif; font-weight:800;
    font-size:clamp(2.4rem,4vw,3.8rem); line-height:0.95;
    letter-spacing:-0.01em; text-transform:uppercase;
    color:var(--navy); margin-bottom:14px;
  }

.btn-primary:hover { background:var(--orange-bright); transform:translateY(-2px); box-shadow:0 8px 24px rgba(232,95,23,0.4); }
  
  .btn-outline:hover { border-color:var(--orange); color:var(--orange); }
  .btn-navy {
    background:var(--navy); color:#fff; padding:14px 34px;
    border-radius:2px; font-size:0.9rem; font-weight:600;
    text-decoration:none; letter-spacing:0.06em; text-transform:uppercase;
    transition:all 0.2s; display:inline-block;
  }
  .btn-navy:hover { background:var(--navy-deep); transform:translateY(-2px); }

.feat-grid-2 { grid-template-columns:repeat(2,1fr); }
  
  .feat-tile:hover { background:#fff; }
  .feat-tile::after { content:''; position:absolute; bottom:0; left:0; right:0; height:3px; background:var(--orange); transform:scaleX(0); transform-origin:left; transition:transform 0.35s ease; }
  .feat-tile:hover::after { transform:scaleX(1); }
  .feat-tag { font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--orange); margin-bottom:12px; }
  .feat-tile h3 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.4rem; letter-spacing:0.04em; text-transform:uppercase; color:var(--navy); margin-bottom:8px; }
  .feat-tile p { font-size:0.87rem; line-height:1.7; color:var(--ink-soft); }

  /* ── STEP LIST ── */
  .steps { display:flex; flex-direction:column; gap:0; }
  .step { display:grid; grid-template-columns:60px 1fr; gap:28px; padding:36px 0; border-bottom:1px solid var(--rule); align-items:start; }
  .step:last-child { border-bottom:none; }
  .step-num { font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:3rem; color:rgba(26,26,26,0.1); line-height:1; text-align:right; }
  .step h3 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.5rem; letter-spacing:0.04em; text-transform:uppercase; color:var(--navy); margin-bottom:8px; }
  .step p { font-size:0.88rem; line-height:1.7; color:var(--ink-soft); }

.check-list li { display:flex; gap:12px; align-items:flex-start; font-size:0.9rem; line-height:1.6; color:var(--ink-mid); }
  .check-list li::before { content:'✓'; color:var(--teal); font-weight:700; flex-shrink:0; margin-top:1px; }

  /* ── ROLE CARDS ── */
  .role-card { background:#fff; border:1px solid var(--rule); border-radius:6px; padding:32px 28px; border-top:3px solid var(--orange); }
  .role-label { font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--orange); margin-bottom:8px; }
  .role-card h3 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.5rem; letter-spacing:0.04em; text-transform:uppercase; color:var(--navy); margin-bottom:10px; }
  .role-card p { font-size:0.86rem; line-height:1.7; color:var(--ink-soft); }

.cta-strip h2 { color:#fff; margin-bottom:10px; }
  .cta-strip p { color:rgba(255,255,255,0.8); font-size:1rem; max-width:480px; margin:0 auto 28px; line-height:1.65; }
  
  .btn-white:hover { background:var(--navy-deep); color:#fff; transform:translateY(-2px); }

.footer-brand p { font-size:0.84rem; color:rgba(255,255,255,0.4); line-height:1.7; margin-top:12px; max-width:250px; }
  .footer-col h4 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--orange); margin-bottom:14px; }
  .footer-col ul { list-style:none; display:flex; flex-direction:column; gap:8px; }
  
  .footer-col a:hover { color:#fff; }
  
  .footer-bottom a { color:rgba(255,255,255,0.35); text-decoration:none; }
  .footer-bottom a:hover { color:var(--orange); }

  .fade-up.on { opacity:1; transform:none; }

.footer-brand p { font-size:0.84rem; color:rgba(255,255,255,0.4); line-height:1.7; margin-top:12px; max-width:250px; }
  .footer-col h4 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--orange); margin-bottom:14px; }
  .footer-col ul { list-style:none; display:flex; flex-direction:column; gap:8px; }
  
  .footer-col a:hover { color:#fff; }
  
  .footer-bottom a { color:rgba(255,255,255,0.35); text-decoration:none; }
  .footer-bottom a:hover { color:var(--orange); }
</style>
<div class="page-hero">
  <div class="page-hero-eyebrow">Resources</div>
  <h1>Frequently Asked <span>Questions</span></h1>
  <p>Quick answers to the most common questions from ADs, coaches, league admins, and super admins.</p>
</div>

<section>
  <div style="max-width:780px;">
    <div class="eyebrow">Getting Started</div>
    <h2>Common Questions</h2>

    <div style="display:flex; flex-direction:column; gap:0; margin-top:8px;" class="fade-up" id="faq-list">

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">How do I get my school set up?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Your Super Admin creates your school record and assigns you as Athletic Director. You'll receive a login invitation by email. From there, add your facilities, create your teams, and you're ready to schedule. Most ADs complete initial setup in under an hour.</p>
        </div>
      </div>

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">Can I import my existing schedule?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Yes. The Schedule Import tool accepts any CSV format. You'll map your columns to ScheduleRama fields, review validation warnings, and commit when ready. Your existing data formatting doesn't need to change — the mapper handles it.</p>
        </div>
      </div>

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">How do I give a coach access?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Add the coach as a Contact record first, then use the "Create User" option on the contact. Set their role to Coach, assign them to their team, and they'll receive a login invitation. The whole process takes about 2 minutes.</p>
        </div>
      </div>

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">What's the difference between Scoped and full access?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Scoped access means a role can perform an action, but only for the schools or leagues they're assigned to. An Athletic Director can edit games at their school, but not at any other school. A League Admin can manage teams inside their leagues, but not school-level data outside of them.</p>
        </div>
      </div>

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">Can a school belong to more than one league?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Yes. A school can be a member of multiple leagues simultaneously — for example, one for soccer and another for basketball. League memberships are managed at the sport level, so there's no conflict between different sports' league structures.</p>
        </div>
      </div>

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">How does Game Finder know who's available?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Game Finder cross-references your target dates against every other school's existing schedule. If a school has a confirmed game on a date, they're excluded from results for that date. Availability is live — as games get confirmed across the platform, results update automatically.</p>
        </div>
      </div>

      <div class="faq-item" style="border-bottom:1px solid var(--rule); padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">What happens when a game is cancelled?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">Cancelled games remain on record with a Cancelled status — they don't disappear from history. You can link a cancellation to a rescheduled replacement game. Both schools see the updated status immediately, and the date opens back up in Game Finder for other requests.</p>
        </div>
      </div>

      <div class="faq-item" style="padding:24px 0;">
        <button class="faq-q" style="background:none; border:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:0;">
          <span style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.2rem; letter-spacing:0.03em; text-transform:uppercase; color:var(--navy);">Is there a mobile version?</span>
          <span class="faq-icon" style="color:var(--orange); font-size:1.2rem; flex-shrink:0; margin-left:16px; transition:transform 0.2s;">+</span>
        </button>
        <div class="faq-a" style="display:none; padding-top:14px;">
          <p style="font-size:0.9rem; line-height:1.7; color:var(--ink-soft);">ScheduleRama is fully responsive and works on any mobile browser. Coaches and ADs frequently use it from their phones to check schedules, respond to inbox requests, and look up contact information on the go.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<div class="cta-strip">
  <h2>Still Have<br>Questions?</h2>
  <p>Our support team is happy to answer anything not covered here — usually within a few hours.</p>
  <a href="/contact/" class="btn-white">Contact Support</a>
</div>
</Base>

