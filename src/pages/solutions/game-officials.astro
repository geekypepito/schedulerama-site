---
import Base from '../../layouts/Base.astro';
const title = "Game Officials";
const description = `Game officials see a sport grid filtered to their assigned leagues and sports with confirmation scoped to their role.`;
---

<Base title={title} description={description} activeSection="solutions">
<style>
.nav-item>a:hover,.nav-item.active>a{color:#fff;}
  .nav-item.has-drop>a::after{content:' ▾';font-size:0.65rem;}
  
  
  .nav-dropdown a:hover{color:#fff;background:rgba(255,255,255,0.06);padding-left:24px;}
  
  .nav-cta:hover{background:var(--orange-bright)!important;}

.page-hero h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.8rem,5vw,4rem);color:#fff;line-height:1.05;margin-bottom:20px;}
  .page-hero p{font-size:1.05rem;color:rgba(255,255,255,0.6);max-width:620px;line-height:1.7;margin-bottom:32px;}
  .hero-actions{display:flex;gap:12px;flex-wrap:wrap;}
  
  .btn-primary:hover{background:var(--orange-bright);}
  
  .btn-outline:hover{border-color:#fff;background:rgba(255,255,255,0.06);}
  section{padding:72px 56px;max-width:1200px;margin:0 auto;}
  .section-alt{background:var(--bg-warm);padding:72px 56px;}
  .section-alt .inner{max-width:1200px;margin:0 auto;}
  h2.section-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.4rem;margin-bottom:12px;}

.feat-card .ico{font-size:1.8rem;margin-bottom:14px;}
  .feat-card h3{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.15rem;margin-bottom:8px;letter-spacing:0.04em;}
  .feat-card p{font-size:0.88rem;color:var(--ink-mid);line-height:1.65;}
  
  .check-list li{font-size:0.92rem;padding-left:24px;position:relative;line-height:1.55;}
  .check-list li::before{content:'✓';position:absolute;left:0;color:var(--teal);font-weight:700;}
  
  .two-col-alt{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
  
  .mock-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
  .mock-title{color:#fff;font-weight:700;font-family:'Barlow Condensed',sans-serif;font-size:1rem;letter-spacing:0.05em;text-transform:uppercase;}
  .mock-badge{background:var(--orange);color:#fff;font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 8px;border-radius:10px;}
  .mock-row{display:flex;justify-content:space-between;align-items:center;padding:9px 12px;border-radius:6px;margin-bottom:6px;background:rgba(255,255,255,0.05);}
  .mock-row:last-child{margin-bottom:0;}
  .mock-label{color:rgba(255,255,255,0.75);}
  .mock-val{font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--orange);}
  .mock-val.ok{color:var(--teal);}
  .mock-val.pend{color:rgba(255,255,255,0.4);}
  .role-tag{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:20px;margin-bottom:12px;}
  .role-tag.orange{background:var(--orange-pale);color:var(--orange);}
  .role-tag.teal{background:var(--teal-pale);color:var(--teal);}
  .role-tag.navy{background:rgba(27,45,79,0.12);color:var(--navy);}
  
  .cta-strip h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.6rem;color:#fff;margin-bottom:12px;}
  .cta-strip p{color:rgba(255,255,255,0.55);margin-bottom:32px;}
  
  .btn-white:hover{background:var(--orange);color:#fff;}

.footer-brand p{font-size:0.84rem;line-height:1.7;margin-top:12px;max-width:250px;}
  .footer-col h4{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:16px;}
  .footer-col ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
  
  .footer-col a:hover{color:#fff;}
  
  .footer-bottom a{color:rgba(255,255,255,0.3);text-decoration:none;}
  
  .js-loaded .fade-up.on{opacity:1;transform:none;}
    
  @media(max-width:1024px){
    .two-col,.two-col-alt{grid-template-columns:1fr;}
      
  }
  .scope-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:5px 12px;font-size:0.78rem;color:rgba(255,255,255,0.6);margin:4px;}
  .scope-pill .dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
  .scope-pill .dot.orange{background:var(--orange);}
  .scope-pill .dot.teal{background:var(--teal);}
</style>
<div class="page-hero">
  <div class="eyebrow">Solutions — Game Officials</div>
  <h1>Officials Confirmation<br>Scoped to Your Leagues</h1>
  <p>Game officials see a sport grid filtered to their assigned leagues and sports — nothing outside their scope. Confirm officiating tasks, receive change notices, and track your upcoming assignments in one place.</p>
  <div class="hero-actions">
    <a href="/contact/" class="btn-primary">Book a Demo</a>
    <a href="/pricing/" class="btn-outline">See Pricing</a>
  </div>
</div>

<section>
  <div class="two-col fade-up">
    <div>
      <div class="eyebrow">Officials Dashboard</div>
      <h2 class="section-title">Your League. Your Sport. Your Games.</h2>
      <p style="color:var(--ink-mid);line-height:1.7;margin-bottom:24px;">Game officials are scoped to specific leagues and sports at assignment. The officials dashboard defaults to a sport grid view, filtered to only the leagues and sports relevant to the official — no unrelated schedule noise.</p>
      <ul class="check-list">
        <li>Sport grid default view filtered by assigned league and sport</li>
        <li>Sport, school, and level filter controls</li>
        <li>Checklist icons show only officials-relevant items</li>
        <li>Office notes from the league admin visible inline</li>
        <li>Inbox with game change notices for assigned league games</li>
        <li>Acknowledge change notices directly from the inbox</li>
      </ul>
    </div>
    <div class="mock-panel fade-up" style="transition-delay:0.1s;">
      <div class="mock-bar">
        <span class="mock-title">Officials Dashboard</span>
      </div>
      <div style="margin-bottom:12px;">
        <div style="font-size:0.72rem;color:rgba(255,255,255,0.3);margin-bottom:8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.08em;">Assigned Scope</div>
        <div style="display:flex;flex-wrap:wrap;">
          <span class="scope-pill"><span class="dot orange"></span>MWL — Var Soccer</span>
          <span class="scope-pill"><span class="dot orange"></span>MWL — JV Soccer</span>
          <span class="scope-pill"><span class="dot teal"></span>SOC — Var Basketball</span>
        </div>
      </div>
      <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:12px;margin-top:4px;">
        <div style="font-size:0.72rem;color:rgba(255,255,255,0.3);margin-bottom:8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.08em;">Upcoming — Officials Items</div>
        <div class="mock-row"><span class="mock-label">Lincoln vs Jefferson — Sep 19</span><span class="mock-val req">⚠ Unconfirmed</span></div>
        <div class="mock-row"><span class="mock-label">Roosevelt vs Madison — Sep 21</span><span class="mock-val ok">✓ Confirmed</span></div>
        <div class="mock-row"><span class="mock-label">Hamilton vs Adams — Sep 26</span><span class="mock-val pend">— Not Assigned</span></div>
      </div>
    </div>
  </div>
</section>

<div class="section-alt">
  <div class="inner">
    <div class="eyebrow fade-up">How Scoping Works</div>
    <h2 class="section-title fade-up">League-Scoped, Sport-Filtered Access</h2>
    <p class="section-sub fade-up">Game official access is managed at the league and sport level. An official assigned to the MWL for soccer sees only MWL soccer games — not basketball, not other leagues, and not schools that aren't part of the MWL.</p>
    <div class="feat-grid">
      <div class="feat-card fade-up">
        <div class="ico">🏆</div>
        <h3>League Assignment</h3>
        <p>Officials are assigned to one or more leagues. Their entire schedule view — games, checklists, change notices — is filtered to those leagues only.</p>
      </div>
      <div class="feat-card fade-up" style="transition-delay:0.08s;">
        <div class="ico">⚽</div>
        <h3>Sport Scoping</h3>
        <p>Within a league, officials can be further scoped to specific sports. A soccer official assigned to MWL won't see MWL basketball games.</p>
      </div>
      <div class="feat-card fade-up" style="transition-delay:0.16s;">
        <div class="ico">🏠</div>
        <h3>Home-Team Confirmation Rule</h3>
        <p>Officials can only confirm officiating checklist items for games where the assigned league's school is the home team — preventing accidental confirms on the wrong side.</p>
      </div>
    </div>
  </div>
</div>

<section>
  <div class="eyebrow fade-up">What Game Officials Can Do</div>
  <h2 class="section-title fade-up">Confirmation Access Without Schedule Control</h2>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;max-width:860px;" class="fade-up">
    <div>
      <ul class="check-list">
        <li>View schedule filtered to assigned leagues and sports</li>
        <li>See sport grid with officials-relevant checklist icons</li>
        <li>Confirm officials checklist items (home-team rule applies)</li>
        <li>Receive game change notices for assigned league/sport games</li>
        <li>Acknowledge game change notices from inbox or email link</li>
        <li>View office notes from league admin</li>
        <li>Multi-team contest visibility on official-facing surfaces</li>
      </ul>
    </div>
    <div>
      <ul class="check-list">
        <li style="color:var(--ink-soft);">Cannot create or edit games</li>
        <li style="color:var(--ink-soft);">Cannot manage teams, contacts, or facilities</li>
        <li style="color:var(--ink-soft);">Cannot confirm transportation or maintenance checklists</li>
        <li style="color:var(--ink-soft);">Cannot see games outside assigned leagues/sports</li>
        <li style="color:var(--ink-soft);">Cannot send game requests</li>
      </ul>
    </div>
  </div>
</section>

<div class="cta-strip">
  <h2>Get Your Officials<br>Coordinated Before Game Day</h2>
  <p>See the officials dashboard and confirmation workflow live in a 30-minute demo.</p>
  <a href="/contact/" class="btn-white">Book a Demo</a>
</div>
</Base>


