---
import Base from '../../layouts/Base.astro';
const title = "Transportation";
const description = `Transportation staff see every upcoming away game, what is planned, what is still missing, and what needs confirming.`;
---

<Base title={title} description={description} activeSection="solutions">
<style>
.nav-item>a:hover,.nav-item.active>a{color:#fff;}
  .nav-item.has-drop>a::after{content:' ▾';font-size:0.65rem;}
  
  
  .nav-dropdown a:hover{color:#fff;background:rgba(255,255,255,0.06);padding-left:24px;}
  
  .nav-cta:hover{background:var(--orange-bright)!important;}

.page-hero h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.8rem,5vw,4rem);color:#fff;line-height:1.05;margin-bottom:20px;}
  .page-hero p{font-size:1.05rem;color:rgba(255,255,255,0.6);max-width:620px;line-height:1.7;margin-bottom:32px;}
  .hero-actions{display:flex;gap:12px;flex-wrap:wrap;}
  
  .btn-primary:hover{background:var(--orange-bright);}
  
  .btn-outline:hover{border-color:#fff;background:rgba(255,255,255,0.06);}
  section{padding:72px 56px;max-width:1200px;margin:0 auto;}
  .section-alt{background:var(--bg-warm);padding:72px 56px;}
  .section-alt .inner{max-width:1200px;margin:0 auto;}
  h2.section-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.4rem;margin-bottom:12px;}

.feat-card .ico{font-size:1.8rem;margin-bottom:14px;}
  .feat-card h3{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.15rem;margin-bottom:8px;letter-spacing:0.04em;}
  .feat-card p{font-size:0.88rem;color:var(--ink-mid);line-height:1.65;}
  
  .check-list li{font-size:0.92rem;padding-left:24px;position:relative;line-height:1.55;}
  .check-list li::before{content:'✓';position:absolute;left:0;color:var(--teal);font-weight:700;}
  
  .two-col-alt{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
  
  .mock-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
  .mock-title{color:#fff;font-weight:700;font-family:'Barlow Condensed',sans-serif;font-size:1rem;letter-spacing:0.05em;text-transform:uppercase;}
  .mock-badge{background:var(--orange);color:#fff;font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 8px;border-radius:10px;}
  .mock-row{display:flex;justify-content:space-between;align-items:center;padding:9px 12px;border-radius:6px;margin-bottom:6px;background:rgba(255,255,255,0.05);}
  .mock-row:last-child{margin-bottom:0;}
  .mock-label{color:rgba(255,255,255,0.75);}
  .mock-val{font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--orange);}
  .mock-val.ok{color:var(--teal);}
  .mock-val.pend{color:rgba(255,255,255,0.4);}
  .role-tag{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:20px;margin-bottom:12px;}
  .role-tag.orange{background:var(--orange-pale);color:var(--orange);}
  .role-tag.teal{background:var(--teal-pale);color:var(--teal);}
  .role-tag.navy{background:rgba(27,45,79,0.12);color:var(--navy);}
  
  .cta-strip h2{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.6rem;color:#fff;margin-bottom:12px;}
  .cta-strip p{color:rgba(255,255,255,0.55);margin-bottom:32px;}
  
  .btn-white:hover{background:var(--orange);color:#fff;}

.footer-brand p{font-size:0.84rem;line-height:1.7;margin-top:12px;max-width:250px;}
  .footer-col h4{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:16px;}
  .footer-col ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
  
  .footer-col a:hover{color:#fff;}
  
  .footer-bottom a{color:rgba(255,255,255,0.3);text-decoration:none;}
  
  .js-loaded .fade-up.on{opacity:1;transform:none;}
    
  @media(max-width:1024px){
    .two-col,.two-col-alt{grid-template-columns:1fr;}
      
  }
  .plan-field{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-radius:6px;background:rgba(255,255,255,0.05);margin-bottom:8px;}
  .plan-label{color:rgba(255,255,255,0.55);font-size:0.8rem;}
  .plan-val{font-family:'JetBrains Mono',monospace;font-size:0.78rem;color:var(--teal);}
  .plan-val.empty{color:rgba(255,255,255,0.2);font-style:italic;}
  .plan-val.req{color:var(--orange);}
</style>
<div class="page-hero">
  <div class="eyebrow">Solutions — Transportation</div>
  <h1>Travel Logistics<br>Without the Chaos</h1>
  <p>Transportation staff get a focused dashboard showing every upcoming away game, what's planned, what's still missing, and what needs confirming — scoped to their school, nothing else.</p>
  <div class="hero-actions">
    <a href="/contact/" class="btn-primary">Book a Demo</a>
    <a href="/pricing/" class="btn-outline">See Pricing</a>
  </div>
</div>

<section>
  <div class="two-col fade-up">
    <div>
      <div class="eyebrow">Transportation Dashboard</div>
      <h2 class="section-title">Your Upcoming Away Games — All in One View</h2>
      <p style="color:var(--ink-mid);line-height:1.7;margin-bottom:24px;">The transportation dashboard shows only what's relevant to your role: upcoming games where the school is traveling, the current status of each transportation plan, and any pending confirmation requests from the AD.</p>
      <ul class="check-list">
        <li>Upcoming away games sorted by date</li>
        <li>Transport checklist status per game at a glance</li>
        <li>Office notes from the Athletic Director visible inline</li>
        <li>Pending confirmation requests surfaced as a work queue</li>
        <li>Secure email-link acknowledgement for change notices</li>
      </ul>
    </div>
    <div class="mock-panel fade-up" style="transition-delay:0.1s;">
      <div class="mock-bar">
        <span class="mock-title">Transportation Dashboard</span>
        <span class="mock-badge">3 Upcoming</span>
      </div>
      <div style="margin-bottom:12px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px;padding:0 4px;font-size:0.7rem;color:rgba(255,255,255,0.3);font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.08em;"><span>Game</span><span>Transport</span></div>
        <div class="mock-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
          <div style="display:flex;width:100%;justify-content:space-between;"><span class="mock-label">@ Jefferson — Sep 19</span><span class="mock-val">✓ Confirmed</span></div>
          <div style="font-size:0.72rem;color:rgba(255,255,255,0.3);">Departs 2:30 PM · Charter Bus</div>
        </div>
        <div class="mock-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
          <div style="display:flex;width:100%;justify-content:space-between;"><span class="mock-label">@ Roosevelt — Sep 26</span><span class="mock-val req">⚠ Incomplete</span></div>
          <div style="font-size:0.72rem;color:rgba(255,255,255,0.3);">Return time missing</div>
        </div>
        <div class="mock-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
          <div style="display:flex;width:100%;justify-content:space-between;"><span class="mock-label">@ Madison — Oct 3</span><span class="mock-val pend">— Not Started</span></div>
          <div style="font-size:0.72rem;color:rgba(255,255,255,0.3);">No plan yet</div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-alt">
  <div class="inner">
    <div class="eyebrow fade-up">Transportation Plans</div>
    <h2 class="section-title fade-up">Log Every Detail Against the Game</h2>
    <p class="section-sub fade-up">Transportation plans live inside the game record. Fill in the core timestamps and logistics, and when the plan is ready, the checklist item confirms automatically.</p>
    <div class="two-col-alt">
      <div class="feat-grid" style="grid-template-columns:1fr;gap:16px;">
        <div class="feat-card fade-up">
          <div class="ico">⏱️</div>
          <h3>Required Fields</h3>
          <p>Depart time, arrive time, and return time are the core fields. Once all three are filled, the transport checklist item is ready to confirm.</p>
        </div>
        <div class="feat-card fade-up" style="transition-delay:0.08s;">
          <div class="ico">📋</div>
          <h3>Optional Detail Fields</h3>
          <p>Carrier, driver, vehicle, pickup location, and destination — capture as much or as little detail as your program needs.</p>
        </div>
        <div class="feat-card fade-up" style="transition-delay:0.16s;">
          <div class="ico">🔗</div>
          <h3>Plan-Driven Confirmation</h3>
          <p>When core timestamps are complete, confirm the transportation checklist item directly from the plan — no double-entry, no extra steps.</p>
        </div>
      </div>
      <div class="mock-panel fade-up" style="transition-delay:0.1s;">
        <div class="mock-bar">
          <span class="mock-title">Transport Plan</span>
          <span class="mock-badge">@ Roosevelt · Sep 26</span>
        </div>
        <div class="plan-field"><span class="plan-label">Depart</span><span class="plan-val">2:00 PM</span></div>
        <div class="plan-field"><span class="plan-label">Arrive</span><span class="plan-val">3:15 PM</span></div>
        <div class="plan-field" style="background:rgba(232,95,23,0.15);"><span class="plan-label">Return ⚠</span><span class="plan-val req">— Required</span></div>
        <div class="plan-field"><span class="plan-label">Carrier</span><span class="plan-val">Valley Charter</span></div>
        <div class="plan-field"><span class="plan-label">Driver</span><span class="plan-val empty">Not entered</span></div>
        <div class="plan-field"><span class="plan-label">Vehicle</span><span class="plan-val">Bus 07</span></div>
        <div class="plan-field"><span class="plan-label">Pickup</span><span class="plan-val">Main Entrance</span></div>
        <div style="margin-top:14px;padding:10px 14px;border-radius:6px;background:rgba(255,200,50,0.1);font-size:0.8rem;color:rgba(255,200,50,0.9);">⚠ Complete return time to enable confirmation</div>
      </div>
    </div>
  </div>
</div>

<section>
  <div class="eyebrow fade-up">What Transportation Staff Can Do</div>
  <h2 class="section-title fade-up">Focused Access, No Schedule Clutter</h2>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;max-width:860px;" class="fade-up">
    <div>
      <ul class="check-list">
        <li>View full school schedule (read-only)</li>
        <li>View and complete transportation plan for each away game</li>
        <li>Confirm transportation checklist items</li>
        <li>View accommodation checklist items</li>
        <li>Receive and acknowledge game change notices</li>
        <li>View office notes from the Athletic Director</li>
      </ul>
    </div>
    <div>
      <ul class="check-list" style="--teal:#e85f17;">
        <li style="color:var(--ink-soft);">Cannot create or edit games</li>
        <li style="color:var(--ink-soft);">Cannot manage teams, contacts, or facilities</li>
        <li style="color:var(--ink-soft);">Cannot confirm facility or officials checklists</li>
        <li style="color:var(--ink-soft);">Cannot send game requests</li>
      </ul>
    </div>
  </div>
</section>

<div class="cta-strip">
  <h2>Give Your Transportation<br>Team Their Own Space</h2>
  <p>See the transportation dashboard and plan workflow live in a 30-minute demo.</p>
  <a href="/contact/" class="btn-white">Book a Demo</a>
</div>
</Base>


