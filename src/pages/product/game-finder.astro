---
import Base from '../../layouts/Base.astro';
const title = "Game Finder";
const description = `Search open opponents by sport, level, and date. Send game requests directly from results. Fill schedule gaps in minutes.`;
---

<Base title={title} description={description} activeSection="product">
<style>

  .nav-item > a:hover, .nav-item.active > a { color:#fff; }
  .nav-item.has-drop > a::after { content:' ▾'; font-size:0.65rem; }
  
  
  .nav-dropdown a:last-child { border-bottom:none; }
  .nav-dropdown a:hover { background:rgba(232,95,23,0.1); color:#fff; padding-left:22px; }
  
  .nav-cta:hover { background:var(--orange-bright) !important; }

.page-hero::before {
    content:''; position:absolute; right:0; top:0; bottom:0; width:40%;
    background:linear-gradient(90deg, transparent, rgba(232,95,23,0.04));
    pointer-events:none;
  }
  .page-hero-eyebrow {
    display:inline-flex; align-items:center; gap:8px;
    font-family:'JetBrains Mono',monospace; font-size:0.65rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--orange);
    margin-bottom:20px;
  }
  .page-hero-eyebrow::before { content:''; display:block; width:28px; height:2px; background:var(--orange); }
  .page-hero h1 {
    font-family:'Barlow Condensed',sans-serif; font-weight:900;
    font-size:clamp(3rem,6vw,5.5rem); line-height:0.92;
    letter-spacing:-0.01em; color:#fff; text-transform:uppercase;
    max-width:700px; margin-bottom:22px;
  }
  .page-hero h1 span { color:var(--orange); }
  .page-hero p {
    font-size:1.1rem; line-height:1.7;
    color:rgba(255,255,255,0.55); max-width:560px;
  }
  .page-hero-actions { display:flex; gap:14px; margin-top:34px; flex-wrap:wrap; }

  /* ── SECTION COMMON ── */
  section { padding:88px 56px; }
  
  .eyebrow::after { content:''; display:block; height:1px; width:36px; background:var(--orange); }
  h2 {
    font-family:'Barlow Condensed',sans-serif; font-weight:800;
    font-size:clamp(2.4rem,4vw,3.8rem); line-height:0.95;
    letter-spacing:-0.01em; text-transform:uppercase;
    color:var(--navy); margin-bottom:14px;
  }

.btn-primary:hover { background:var(--orange-bright); transform:translateY(-2px); box-shadow:0 8px 24px rgba(232,95,23,0.4); }
  
  .btn-outline:hover { border-color:var(--orange); color:var(--orange); }
  .btn-navy {
    background:var(--navy); color:#fff; padding:14px 34px;
    border-radius:2px; font-size:0.9rem; font-weight:600;
    text-decoration:none; letter-spacing:0.06em; text-transform:uppercase;
    transition:all 0.2s; display:inline-block;
  }
  .btn-navy:hover { background:var(--navy-deep); transform:translateY(-2px); }

.feat-grid-2 { grid-template-columns:repeat(2,1fr); }
  
  .feat-tile:hover { background:#fff; }
  .feat-tile::after { content:''; position:absolute; bottom:0; left:0; right:0; height:3px; background:var(--orange); transform:scaleX(0); transform-origin:left; transition:transform 0.35s ease; }
  .feat-tile:hover::after { transform:scaleX(1); }
  .feat-tag { font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--orange); margin-bottom:12px; }
  .feat-tile h3 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.4rem; letter-spacing:0.04em; text-transform:uppercase; color:var(--navy); margin-bottom:8px; }
  .feat-tile p { font-size:0.87rem; line-height:1.7; color:var(--ink-soft); }

  /* ── STEP LIST ── */
  .steps { display:flex; flex-direction:column; gap:0; }
  .step { display:grid; grid-template-columns:60px 1fr; gap:28px; padding:36px 0; border-bottom:1px solid var(--rule); align-items:start; }
  .step:last-child { border-bottom:none; }
  .step-num { font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:3rem; color:rgba(26,26,26,0.1); line-height:1; text-align:right; }
  .step h3 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.5rem; letter-spacing:0.04em; text-transform:uppercase; color:var(--navy); margin-bottom:8px; }
  .step p { font-size:0.88rem; line-height:1.7; color:var(--ink-soft); }

.check-list li { display:flex; gap:12px; align-items:flex-start; font-size:0.9rem; line-height:1.6; color:var(--ink-mid); }
  .check-list li::before { content:'✓'; color:var(--teal); font-weight:700; flex-shrink:0; margin-top:1px; }

  /* ── ROLE CARDS ── */
  .role-card { background:#fff; border:1px solid var(--rule); border-radius:6px; padding:32px 28px; border-top:3px solid var(--orange); }
  .role-label { font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--orange); margin-bottom:8px; }
  .role-card h3 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.5rem; letter-spacing:0.04em; text-transform:uppercase; color:var(--navy); margin-bottom:10px; }
  .role-card p { font-size:0.86rem; line-height:1.7; color:var(--ink-soft); }

.cta-strip h2 { color:#fff; margin-bottom:10px; }
  .cta-strip p { color:rgba(255,255,255,0.8); font-size:1rem; max-width:480px; margin:0 auto 28px; line-height:1.65; }
  
  .btn-white:hover { background:var(--navy-deep); color:#fff; transform:translateY(-2px); }

.footer-brand p { font-size:0.84rem; color:rgba(255,255,255,0.4); line-height:1.7; margin-top:12px; max-width:250px; }
  .footer-col h4 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--orange); margin-bottom:14px; }
  .footer-col ul { list-style:none; display:flex; flex-direction:column; gap:8px; }
  
  .footer-col a:hover { color:#fff; }
  
  .footer-bottom a { color:rgba(255,255,255,0.35); text-decoration:none; }
  .footer-bottom a:hover { color:var(--orange); }

  .fade-up.on { opacity:1; transform:none; }

.footer-brand p { font-size:0.84rem; color:rgba(255,255,255,0.4); line-height:1.7; margin-top:12px; max-width:250px; }
  .footer-col h4 { font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:0.9rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--orange); margin-bottom:14px; }
  .footer-col ul { list-style:none; display:flex; flex-direction:column; gap:8px; }
  
  .footer-col a:hover { color:#fff; }
  
  .footer-bottom a { color:rgba(255,255,255,0.35); text-decoration:none; }
  .footer-bottom a:hover { color:var(--orange); }
</style>
<div class="page-hero">
  <div class="page-hero-eyebrow">Product</div>
  <h1>Game <span>Finder</span></h1>
  <p>Find open opponents by date, sport, and level. Send a request in seconds. No cold calls. No email chains. Just a confirmed game.</p>
  <div class="page-hero-actions">
    <a href="/contact/" class="btn-primary">Book a Demo</a>
    <a href="/solutions/coaches/" class="btn-outline">Coach's Guide</a>
  </div>
</div>

<section>
  <div class="eyebrow">Find &amp; Book</div>
  <h2>Open Dates Filled<br>in Minutes</h2>
  <p class="section-sub">Stop calling around. Game Finder shows you exactly who's available when you are — filtered by the sport, level, and dates that matter to your program.</p>
  <div class="feat-grid fade-up">
    <div class="feat-tile">
      <div class="feat-tag">Search</div>
      <h3>Filter by What Matters</h3>
      <p>Search by sport, level (Varsity, JV, Freshman), date range, and location radius. Results update in real time — no page reloads, no guessing.</p>
    </div>
    <div class="feat-tile">
      <div class="feat-tag">Availability</div>
      <h3>Live Open Dates</h3>
      <p>See which schools have open dates on your target window. Availability is live — if a school just confirmed another game, it disappears from results automatically.</p>
    </div>
    <div class="feat-tile">
      <div class="feat-tag">Request</div>
      <h3>One-Click Request</h3>
      <p>Select a school, pick your preferred date and venue, add any notes, and send. The other team's AD or coach is notified immediately inside their Inbox.</p>
    </div>
    <div class="feat-tile">
      <div class="feat-tag">History</div>
      <h3>Past Opponent Lookup</h3>
      <p>See your history with any school — games played, record, and request history. Know before you reach out whether it's been a reliable scheduling partner.</p>
    </div>
    <div class="feat-tile">
      <div class="feat-tag">Tracking</div>
      <h3>Request Status</h3>
      <p>Every request you send is tracked in your Inbox. See when it was viewed, if a response is pending, and get notified the moment anything changes.</p>
    </div>
    <div class="feat-tile">
      <div class="feat-tag">Workflow</div>
      <h3>Seamless to Schedule</h3>
      <p>When a request is accepted, the game appears on both schools' schedules instantly. No double-entry. No confirmation emails to dig through. Just a game on the calendar.</p>
    </div>
  </div>
</section>

<section style="background:var(--navy); padding:88px 56px;">
  <div class="eyebrow" style="color:var(--orange);">The Old Way vs. The New Way</div>
  <h2 style="color:#fff;">Why Coaches<br>Love Game Finder</h2>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:8px;" class="fade-up">
    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:6px; padding:32px;">
      <h3 style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.3rem; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:20px;">Before ScheduleRama</h3>
      <ul style="list-style:none; display:flex; flex-direction:column; gap:12px;">
        <li style="font-size:0.87rem; color:rgba(255,255,255,0.4); padding-left:18px; position:relative;">⬜ Call 6 schools, leave 4 voicemails</li>
        <li style="font-size:0.87rem; color:rgba(255,255,255,0.4); padding-left:18px; position:relative;">⬜ Wait 3 days for responses</li>
        <li style="font-size:0.87rem; color:rgba(255,255,255,0.4); padding-left:18px; position:relative;">⬜ Send confirmation email, hope it doesn't get lost</li>
        <li style="font-size:0.87rem; color:rgba(255,255,255,0.4); padding-left:18px; position:relative;">⬜ Manually add game to your spreadsheet</li>
        <li style="font-size:0.87rem; color:rgba(255,255,255,0.4); padding-left:18px; position:relative;">⬜ Email the AD so they update their records too</li>
        <li style="font-size:0.87rem; color:rgba(255,255,255,0.4); padding-left:18px; position:relative;">⬜ Discover a conflict the week of the game</li>
      </ul>
    </div>
    <div style="background:rgba(232,95,23,0.07); border:1px solid rgba(232,95,23,0.2); border-radius:6px; padding:32px;">
      <h3 style="font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:1.3rem; text-transform:uppercase; color:#fff; margin-bottom:20px;">With ScheduleRama</h3>
      <ul class="check-list" style="--teal:#1aab8a;">
        <li style="color:rgba(255,255,255,0.75);">Search open opponents in real time</li>
        <li style="color:rgba(255,255,255,0.75);">Send a request in under 60 seconds</li>
        <li style="color:rgba(255,255,255,0.75);">Get notified the moment they respond</li>
        <li style="color:rgba(255,255,255,0.75);">Game auto-adds to both schools' schedules</li>
        <li style="color:rgba(255,255,255,0.75);">Full message thread tied to the game</li>
        <li style="color:rgba(255,255,255,0.75);">Conflict detection built in</li>
      </ul>
    </div>
  </div>
</section>

<div class="cta-strip">
  <h2>Stop Cold-Calling<br>Other Coaches</h2>
  <p>Game Finder puts every available opponent right in front of you — sorted, filtered, and ready to request.</p>
  <a href="/contact/" class="btn-white">See It In Action</a>
</div>
</Base>

